# Devin API
DEVIN_API_KEY=replace-me
DEVIN_ORG_ID=replace-me
DEVIN_API_BASE=https://api.devin.ai/v3

# GitHub
GITHUB_TOKEN=replace-me
GITHUB_WEBHOOK_SECRET=replace-me
GITHUB_API_BASE=https://api.github.com

# Optional: GitHub App auth (production-correct alternative to a PAT).
# When set, the orchestrator authenticates as a GitHub App and posts
# comments under the App's bot identity. github_token is then unused.
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=/app/devin-orchestrator.private-key.pem

# App
APP_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:////data/devin.db

# Optional
TARGET_REPO=
BOT_GITHUB_LOGIN=

# Polling
POLLER_INTERVAL_SECONDS=45
POLLER_ENABLED=true
POLLER_CONCURRENCY=8

# Caps new Devin sessions per (repo, rolling 60 minutes). 0 = unlimited.
RATE_LIMIT_SESSIONS_PER_HOUR=30
